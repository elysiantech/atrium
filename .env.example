# Google Calendar — private iCal URL (Settings → Integrate calendar → "Secret address in iCal format")
VITE_ICAL_URL=

# Weather location — Open-Meteo (no API key required)
VITE_WEATHER_CITY=Oakland
VITE_WEATHER_STATE=CA

# Optional override: direct URL to a background image (defaults to an Unsplash landscape)
# VITE_BACKGROUND_IMAGE_URL=
